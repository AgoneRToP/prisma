<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Регистрация</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <style>
    body { background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%); min-height: 100vh; display: flex; align-items: center; padding: 20px 0; }
    .auth-card { border: none; border-radius: 16px; box-shadow: 0 8px 24px rgba(0,0,0,0.1); background: #ffffff; }
    .btn-google { background-color: #ffffff; color: #444; border: 1px solid #ddd; font-weight: 500; transition: all 0.2s; }
    .btn-google:hover { background-color: #f8f9fa; border-color: #ccc; }
    .divider { display: flex; align-items: center; text-align: center; color: #888; margin: 20px 0; }
    .divider::before, .divider::after { content: ''; flex: 1; border-bottom: 1px solid #eee; }
    .divider:not(:empty)::before { margin-right: .5em; }
    .divider:not(:empty)::after { margin-left: .5em; }
  </style>
</head>
<body>

<div class="container">
  <div class="row justify-content-center">
    <div class="col-10 col-sm-8 col-md-6 col-lg-4">
      
      <div class="card auth-card p-4">
        <div class="text-center mb-4">
          <h3 class="fw-bold text-primary">Регистрация</h3>
          <p class="text-muted small">Создайте новый профиль за пару кликов</p>
        </div>

        <!-- КНОПКА GOOGLE OAUTH -->
        <div class="d-grid mb-2">
          <a href="/auth/google" class="btn btn-google py-2">
            <i class="bi bi-google me-2 text-danger"></i> Регистрация через Google
          </a>
        </div>

        <div class="divider">или заполните форму</div>

        <!-- ФОРМА РЕГИСТРАЦИИ -->
        <form action="/auth/register" method="POST">
          <div class="mb-2">
            <label class="form-label small fw-semibold">Ваше имя</label>
            <input type="text" name="name" class="form-control" placeholder="Иван" required>
          </div>

          <div class="mb-2">
            <label class="form-label small fw-semibold">Возраст</label>
            <input type="number" name="age" class="form-control" placeholder="25" min="1" max="120" required>
          </div>

          <div class="mb-2">
            <label class="form-label small fw-semibold">Email адрес</label>
            <input type="email" name="email" class="form-control" placeholder="name@example.com" required>
          </div>
          
          <div class="mb-4">
            <label class="form-label small fw-semibold">Пароль</label>
            <input type="password" name="password" class="form-control" placeholder="Минимум 6 символов" minlength="6" required>
          </div>

          <div class="d-grid mb-2">
            <button type="submit" class="btn btn-success py-2 fw-semibold">Зарегистрироваться</button>
          </div>
        </form>

        <div class="text-center mt-3">
          <p class="small text-muted mb-0">Уже зарегистрированы? <a href="/auth/login" class="text-decoration-none">Войти</a></p>
        </div>
      </div>

    </div>
  </div>
</div>

</body>
</html>
