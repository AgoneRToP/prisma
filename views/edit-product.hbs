<html lang='ru'>
  <head>
    <meta charset='UTF-8' /><title>Редактирование</title>
    <link
      href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css'
      rel='stylesheet'
    />
  </head>
  <body class='bg-light p-5'>
    <div class='container col-md-6 bg-white p-4 rounded shadow-sm'>
      <h3 class='mb-4 text-primary'>✏️ Редактирование товара #{{product.id}}</h3>

      <!-- Форма отправляет POST на URL обновления -->
      <form action='/products/{{product.id}}/update' method='POST'>

        <!-- Название товара на разных языках -->
        <div class='card p-3 mb-3 bg-light'>
          <label class='form-label fw-bold'>Название товара</label>
          <input
            type='text'
            name='name[eng]'
            class='form-control mb-2'
            value='{{product.name.english}}'
            placeholder='English'
          />
          <input
            type='text'
            name='name[рус]'
            class='form-control mb-2'
            value='{{product.name.русский}}'
            placeholder='Русский'
          />
          <input
            type='text'
            name='name[uzb]'
            class='form-control mb-2'
            value='{{product.name.o_zbekcha}}'
            placeholder="O'zbekcha"
          />
          <input
            type='text'
            name='name[узб]'
            class='form-control'
            value='{{product.name.узб}}'
            placeholder='Ўзбекча'
          />
        </div>

        <!-- Описание товара на разных языках -->
        <div class='card p-3 mb-3 bg-light'>
          <label class='form-label fw-bold'>Описание товара</label>
          <textarea
            name='description[english]'
            class='form-control mb-2'
            rows='2'
            placeholder='English'
          >{{product.description.english}}</textarea>
          <textarea
            name='description[русский]'
            class='form-control mb-2'
            rows='2'
            placeholder='Русский'
          >{{product.description.русский}}</textarea>
          <textarea
            name='description[o_zbekcha]'
            class='form-control mb-2'
            rows='2'
            placeholder="O'zbekcha"
          >{{product.description.o_zbekcha}}</textarea>
          <textarea
            name='description[узб]'
            class='form-control'
            rows='2'
            placeholder='Ўзбекча'
          >{{product.description.узб}}</textarea>
        </div>

        <!-- Общие числовые поля -->
        <div class='row'>
          <div class='col-6 mb-3'>
            <label class='form-label fw-bold'>Цена ($)</label>
            <input
              type='number'
              name='price'
              step='0.01'
              class='form-control'
              value='{{product.price}}'
              required
            />
          </div>
          <div class='col-6 mb-3'>
            <label class='form-label fw-bold'>Количество</label>
            <input
              type='number'
              name='quantity'
              class='form-control'
              value='{{product.quantity}}'
              required
            />
          </div>
        </div>

        <div class='d-flex justify-content-between mt-3'>
          <a href='/products' class='btn btn-secondary'>🔙 К списку</a>
          <button type='submit' class='btn btn-success px-4'>💾 Сохранить</button>
        </div>
      </form>
    </div>
  </body>
</html>